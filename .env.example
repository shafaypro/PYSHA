# =============================================================================
# PYSHA v2 Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Engine Selection ---
PYSHA_STT_ENGINE=google          # google | whisper | deepgram | <custom>
PYSHA_TTS_ENGINE=edge            # edge | pyttsx | openai | <custom>
PYSHA_LLM_ENGINE=anthropic       # anthropic | openai | ollama | <custom>

# --- LLM API Keys ---
PYSHA_ANTHROPIC_API_KEY=
PYSHA_OPENAI_API_KEY=
PYSHA_OLLAMA_BASE_URL=http://localhost:11434

# --- LLM Model Selection ---
PYSHA_ANTHROPIC_MODEL=claude-sonnet-4-20250514
PYSHA_OPENAI_MODEL=gpt-4o
PYSHA_OLLAMA_MODEL=llama3.1

# --- Speech Settings ---
PYSHA_STT_LANGUAGE=en-US
PYSHA_TTS_VOICE=en-US-AriaNeural  # Edge TTS voice name
PYSHA_TTS_RATE=+0%                # Edge TTS speaking rate

# --- Skill API Keys ---
PYSHA_WOLFRAM_APP_ID=
PYSHA_DEEPGRAM_API_KEY=

# --- Web UI ---
PYSHA_WEB_HOST=127.0.0.1
PYSHA_WEB_PORT=8000

# --- General ---
PYSHA_LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
PYSHA_ASSISTANT_NAME=PYSHA
PYSHA_DATA_DIR=~/.pysha           # Where to store databases, caches, etc.
